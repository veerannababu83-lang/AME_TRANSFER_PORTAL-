                <div class="section-dot"></div>
                <h3 class="section-title"><span class="step-badge">Step 3</span> Last Transfer Details</h3>
                <div class="grid-2">
                    <div class="form-group"><label>From Base</label>
                        <select id="cLastTransferFrom"><option value="">--From Base--</option></select>
                    </div>
                    <div class="form-group"><label>To Base</label>
