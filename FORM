                    <div class="form-group"><label>Priority 1 (Mandatory)</label><select id="cP1"><option value="">--Select Base--</option></select></div>
                    <div class="form-group"><label>Priority 2 (Optional)</label><select id="cP2"><option value="">--Select Base--</option></select></div>
                    <div class="form-group"><label>Priority 3 (Optional)</label><select id="cP3"><option value="">--Select Base--</option></select></div>
