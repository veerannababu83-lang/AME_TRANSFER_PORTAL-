<style>
    body { background: #f8fafc; margin:0; font-family: 'Segoe UI', sans-serif; }
    :root {
        --primary: #2b50a1; /* Indigo Blue */
        --accent: #FFD700;  /* Gold */
        --white: #fff;
    }
    .portal-btn {
        padding: 15px 30px;
        border: none;
        border-radius: 50px;
        font-size: 1rem;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
        text-decoration: none;
        display: block;
        box-shadow: 0 4px 15px rgba(43,80,161,0.08);
    }
    .portal-btn.primary {
        background: var(--primary);
        color: var(--white);
        border: 2px solid var(--primary);
    }
    .portal-btn.secondary {
        background: var(--white);
        color: var(--primary);
        border: 2px solid var(--primary);
    }
    .portal-btn:hover { transform: translateY(-3px); box-shadow: 0 6px 18px rgba(43,80,161,0.15); }
    .portal-btn.primary:hover { background: #005a9e; border-color: #005a9e; }
    .portal-btn.secondary:hover { background: #f0f4f8; }
    #transferPortal {
        background: #fff; max-width: 800px; margin: 32px auto; border-radius: 18px; box-shadow: 0 8px 32px rgba(0,0,0,0.12);
        padding: 0; font-family: 'Segoe UI', sans-serif; border: 1px solid #e3e8f0;
        overflow: hidden;
    }
    
    /* Header Styles */
    .portal-header {
        background: linear-gradient(135deg, #1e3a8a 0%, #2b50a1 100%);
        padding: 2rem;
        color: white;
        position: relative;
    }
    #formTitle { color: white; text-align: left; margin: 0 0 0.5rem 0; font-size: 1.75rem; font-weight: 700; }
    .header-subtitle { color: #dbeafe; font-size: 1rem; margin-bottom: 1.5rem; }
    
    #userBadge {
        background: rgba(255,255,255,0.1); backdrop-filter: blur(4px); border: 1px solid rgba(255,255,255,0.2);
        border-radius: 8px; padding: 0.75rem 1rem; display: inline-flex; flex-direction: column; gap: 0.25rem;
        font-size: 0.85rem; color: #bfdbfe; width: auto; margin-bottom: 0;
    }
    #userBadge strong { color: white; }

    /* Body & Section Styles */
    .portal-body { padding: 2rem; }
    
    .form-section {
        position: relative; padding-left: 2rem; border-left: 2px solid #dbeafe;
        margin-bottom: 0; padding-bottom: 2.5rem;
    }
    .form-section:last-child { border-left-color: transparent; padding-bottom: 0; }
    
    .section-dot {
        position: absolute; left: -9px; top: 0; width: 1rem; height: 1rem;
        border-radius: 50%; background-color: #dbeafe; border: 2px solid white;
        box-shadow: 0 0 0 1px #fff;
    }
    
    .section-title {
        font-size: 1.1rem; font-weight: 700; color: #111827; margin: 0 0 1.5rem 0;
        display: flex; align-items: center;
    }
    
    .step-badge {
        background-color: #eff6ff; color: #2b50a1; padding: 0.25rem 0.75rem;
        border-radius: 9999px; font-size: 0.75rem; font-weight: 700; margin-right: 0.75rem;
        border: 1px solid #dbeafe; text-transform: uppercase; letter-spacing: 0.05em;
    }

    /* Grid & Inputs */
    .grid-2 { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
    .grid-3 { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
    @media (min-width: 600px) {
        .grid-2 { grid-template-columns: 1fr 1fr; }
        .grid-3 { grid-template-columns: 1fr 1fr 1fr; }
    }
    
    .form-group { width: 100%; margin-bottom: 0; }
    .form-group label { font-size: 0.9rem; font-weight: 600; color: #4b5563; margin-bottom: 0.5rem; display: block; }
    input, select, textarea {
        width: 100%; padding: 0.75rem; border: 1px solid #e5e7eb; border-radius: 0.5rem;
        font-size: 0.95rem; background: #f9fafb; box-sizing: border-box; transition: all 0.2s;
    }
    input:focus, select:focus, textarea:focus {
        border-color: #2b50a1; background: #fff; outline: none;
        box-shadow: 0 0 0 3px rgba(43, 80, 161, 0.1);
    }

    #finalSubmitBtn {
        width: 100%; padding: 15px; background: linear-gradient(90deg, #0078d4 60%, #2b50a1 100%);
        color: white; border: none; border-radius: 8px; font-size: 1.1rem; font-weight: bold;
        cursor: pointer; transition: 0.3s; margin-top: 1rem;
    }
    #finalSubmitBtn:hover { background: #005a9e; }
    #statusMsg { text-align: center; font-weight: 600; margin-top: 18px; min-height: 24px; }
    
    @media (max-width: 700px) {
        #transferPortal { margin: 10px; }
        .portal-header, .portal-body { padding: 1.5rem; }
    }
    /* Hide 6E skai bot */
    img[src*="chatbot.gif"] {
        display: none !important;
    }
    /* Hide HRGPT iframe */
    #cx-iframe, .cx-iframe {
        display: none !important;
    }
    /* Hide SharePoint Navigation & Chrome */
    #suiteBarDelta, #s4-ribbonrow, #s4-titlerow, #sideNavBox, #spSiteHeader { display: none !important; }
    button[data-automation-id="pageCommandBarFocusModeButton"] { display: none !important; }
    #contentBox { margin-left: 0 !important; }

    /* Custom Header Styles */
    .custom-header {
        background-color: var(--primary);
        color: var(--white);
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        position: sticky;
        top: 0;
        z-index: 50;
        border-bottom: 4px solid var(--accent);
        padding: 0;
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .header-content {
        width: 100%;
        max-width: 1280px;
        padding: 0 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 100%;
    }
    .brand-container { display: flex; align-items: center; text-decoration: none; color: white; }
    .brand-container:hover .logo-circle { transform: rotate(45deg); }
    .logo-circle {
        background-color: white; padding: 8px; bordear-radius: 50%; margin-right: 12px;
        display: flex; align-items: center; justify-content: center; transition: transform 0.3s;
    }
    .logo-icon { font-size: 20px; line-height: 1; color: var(--primary); }
    .brand-text { display: flex; flex-direction: column; }
    .brand-title { font-family: 'Segoe UI', sans-serif; font-weight: 700; font-size: 1.25rem; line-height: 1; letter-spacing: -0.025em; }
    .brand-subtitle { font-family: monospace; font-size: 10px; color: #e0e7ff; letter-spacing: 0.1em; text-transform: uppercase; margin-top: 4px; opacity: 0.8; }
    
    .nav-links { display: flex; gap: 2rem; height: 100%; }
    .nav-item {
        display: inline-flex; align-items: center; padding-top: 4px;
        font-size: 0.875rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
        color: #e0e7ff; text-decoration: none; border-bottom: 2px solid transparent; transition: all 0.2s; height: 100%;
    }
    .nav-item:hover { color: white; border-bottom-color: rgba(255,255,255,0.5); }
    .nav-item.active { color: var(--accent); border-bottom-color: var(--accent); }
</style>

