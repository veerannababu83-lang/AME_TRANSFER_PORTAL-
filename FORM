<div id="transferPortal">
    <!-- Header Section -->
    <div class="portal-header">
        <h2 id="formTitle">AME Transfer Portal</h2>
        <div class="header-subtitle">Submit your details to apply for a base transfer.</div>
        <div id="userBadge">
