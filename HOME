<script>
// Animated scrolling messages
(function() {
    const subtitles = [
        'Submit your transfer requests easily',
        'Track your ranking in real-time',
        'Transparent & automated process'
    ];
    const subtitleEl = document.getElementById('rotatingSubtitle');
    let idx = 0;
    setInterval(() => {
        idx = (idx + 1) % subtitles.length;
        if(subtitleEl) subtitleEl.innerText = subtitles[idx];
    }, 3000);
})();
</script>
